#!/usr/bin/env bash

set -euo pipefail

CACHE_TTL_SECONDS="${GITHUB_REPO_CHOOSER_CACHE_TTL_SECONDS:-300}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/hammerspoon"
CACHE_FILE="$CACHE_DIR/github-repo-choices.json"
TMP_FILE="$CACHE_FILE.tmp.$$"
REFRESH_LOCK_DIR="$CACHE_FILE.lock"
SCRIPT_PATH="$0"
HAS_REFRESH_LOCK=0

log() {
  printf '%s\n' "$*" >&2
}

status() {
  log "STATUS: $*"
}

cache_is_fresh() {
  [ -f "$CACHE_FILE" ] || return 1

  now="$(date +%s)"
  modified_at="$(stat -f %m "$CACHE_FILE" 2>/dev/null)" || return 1

  [ $((now - modified_at)) -lt "$CACHE_TTL_SECONDS" ]
}

write_cache() {
  mkdir -p "$CACHE_DIR"
  printf '%s\n' "$1" > "$TMP_FILE"
  mv "$TMP_FILE" "$CACHE_FILE"
}

print_cache() {
  cat "$CACHE_FILE"
}

acquire_refresh_lock() {
  mkdir -p "$CACHE_DIR"

  if mkdir "$REFRESH_LOCK_DIR" 2>/dev/null; then
    HAS_REFRESH_LOCK=1
    return 0
  fi

  return 1
}

wait_for_cache() {
  attempts=30

  while [ "$attempts" -gt 0 ]; do
    if [ -f "$CACHE_FILE" ]; then
      return 0
    fi

    sleep 1
    attempts=$((attempts - 1))
  done

  return 1
}

refresh_cache() {
  status "Refreshing GitHub repos"

  if fresh_json="$(build_choices)"; then
    write_cache "$fresh_json"
    return 0
  fi

  log "ERROR: Could not build GitHub repo choices"
  return 1
}

refresh_cache_with_lock() {
  if ! acquire_refresh_lock; then
    status "GitHub repo refresh already in progress"
    return 1
  fi

  refresh_cache
}

format_choices() {
  format="$1"

  case "$format" in
    default)
      cat
      ;;
    alfred)
      jq '{
        cache: { seconds: 300, loosereload: true },
        items: map({
          uid: .text,
          title: .text,
          subtitle: (.subText // ""),
          arg: .url,
          match: (.text + " " + (.subText // "")),
          quicklookurl: .url,
          valid: true,
          variables: {
            repo: .text,
            url: .url
          }
        })
      }'
      ;;
    *)
      log "ERROR: Unsupported format '$format'"
      return 1
      ;;
  esac
}

build_choices() {
  status "Fetching GitHub owners"

  owners_json="$({
    gh api user --jq .login | jq -R .
    gh api user/orgs --paginate --jq '.[].login' | jq -R .
  } | jq -s 'map(select(length > 0)) | unique')"

  if [ "$(printf '%s' "$owners_json" | jq 'length')" -eq 0 ]; then
    log "ERROR: No GitHub owners found"
    return 1
  fi

  printf '%s' "$owners_json" | jq -r '.[]' | while IFS= read -r owner; do
    status "Loading repos for $owner"
    gh repo list "$owner" --limit 1000 --json nameWithOwner,url,description,pushedAt
  done | jq -s '
    add
    | unique_by(.nameWithOwner)
    | map({
        text: .nameWithOwner,
        subText: (.description // .url),
        url: .url,
        pushedAt: (.pushedAt // "")
      })
    | sort_by(.nameWithOwner)
    | sort_by(.pushedAt)
    | reverse
  '
}

load_choices_json() {
  if [ -f "$CACHE_FILE" ] && cache_is_fresh; then
      status "Using cached GitHub repos"
      print_cache
      return 0
  fi

  if refresh_cache_with_lock; then
    print_cache
    return 0
  fi

  if wait_for_cache; then
    status "Using GitHub repo cache after waiting for refresh"
    print_cache
    return 0
  fi

  log "ERROR: Could not build GitHub repo choices"
  return 1
}

cleanup() {
  rm -f "$TMP_FILE"

  if [ "$HAS_REFRESH_LOCK" -eq 1 ]; then
    rmdir "$REFRESH_LOCK_DIR" 2>/dev/null || true
  fi
}

trap cleanup EXIT

output_format="default"
refresh_only=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    list)
      shift
      ;;
    --format=*)
      output_format="${1#--format=}"
      shift
      ;;
    --refresh-only)
      refresh_only=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [ "$refresh_only" -eq 1 ]; then
  if cache_is_fresh; then
    status "GitHub repo cache already fresh"
    exit 0
  fi

  if refresh_cache_with_lock; then
    exit 0
  fi

  if cache_is_fresh; then
    exit 0
  fi

  log "ERROR: Could not refresh GitHub repo choices"
  exit 1
fi

if [ "$#" -gt 0 ]; then
  log "ERROR: Unsupported arguments: $*"
  exit 1
fi

if choices_json="$(load_choices_json)"; then
  printf '%s\n' "$choices_json" | format_choices "$output_format"
  exit 0
fi

log "ERROR: Could not build GitHub repo choices"
exit 1
